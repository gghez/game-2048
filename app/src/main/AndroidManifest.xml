<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
      allowBackup below is intentionally kept true (an explicit decision, not just the
      framework default). Android Auto Backup then includes our DataStore prefs
      (best score, settings, in-progress saved game) so progress survives a device
      migration or reinstall. The app collects and transmits nothing, so backing up
      this purely local data carries no privacy cost. Rationale: docs/privacy.md.
    -->
    <application
        android:name=".Game2048App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Game2048">

        <!--
          Google Play Games (optional). The v2 SDK auto-initializes at launch and
          REQUIRES a valid numeric APP_ID; an empty value crashes the app. So this
          meta-data stays commented out by default and the app uses NoopLeaderboard,
          which keeps it runnable without a Play Console account.
          Enabling it is a deployment step — see the GitHub issue labelled "deployment".
        -->
        <!--
        <meta-data
            android:name="com.google.android.gms.games.APP_ID"
            android:value="@string/game_services_project_id" />
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
